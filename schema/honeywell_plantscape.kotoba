// Honeywell_plantscape clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace honeywell_plantscape {

    entity Tag {
        id: string @unique
        address: string
        name: string
        value: float
        quality: string
        unit: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Device {
        id: string @unique
        name: string
        protocol: string
        ipAddress: string
        online: boolean
        createdAt: datetime
        updatedAt: datetime
    }

    entity Alarm {
        id: string @unique
        tagId: string
        priority: string
        state: string
        raisedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Trend {
        id: string @unique
        tagId: string
        sampleRateMs: integer
        retentionDays: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity ControlLoop {
        id: string @unique
        name: string
        setpoint: float
        processValue: float
        mode: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Batch {
        id: string @unique
        recipe: string
        status: string
        startedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
